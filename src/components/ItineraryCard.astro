---
interface Props {
  slug: string;
  citySlug: string;
  title: string;
  duration: string;
  vibe: string;
  cost: string;
  description: string;
}
const { slug, citySlug, title, duration, vibe, cost, description } = Astro.props;
---
<a href={`/${citySlug}/itinerary/${slug}`} class="itinerary-card">
  <div class="meta-row">
    <span class="vibe">{vibe}</span>
    <span class="divider">·</span>
    <span class="detail">{duration}</span>
    <span class="divider">·</span>
    <span class="detail">{cost}</span>
  </div>
  <h3 class="title">{title}</h3>
  <p class="desc">{description}</p>
  <span class="enter">View route →</span>
</a>

<style>
  .itinerary-card {
    display: block;
    padding: 28px 32px;
    background: var(--surface);
    border-radius: 4px;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.15s ease;
    border: 1px solid var(--line);
  }
  .itinerary-card:hover { transform: translateY(-2px); }
  .meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .vibe {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .divider { color: var(--line); }
  .detail { font-size: 12px; color: var(--muted); }
  .title {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 400;
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .enter { font-size: 13px; font-weight: 500; color: var(--accent); }
</style>
