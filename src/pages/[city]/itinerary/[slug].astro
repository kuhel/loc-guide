---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  const paths = [];
  for (const city of cities) {
    for (const route of city.data.routes) {
      paths.push({
        params: { city: city.data.meta.slug, slug: route.slug },
        props: { route, cityMeta: city.data.meta, places: city.data.places },
      });
    }
  }
  return paths;
}

const { route, cityMeta, places } = Astro.props;

// Build a map of place name → image as fallback
const placeImageMap: Record<string, string> = {};
for (const p of places) {
  if (p.image) placeImageMap[p.name.toLowerCase()] = p.image;
}

function stepImage(step: { image?: string; place_name: string }): string | null {
  return step.image ?? placeImageMap[step.place_name.toLowerCase()] ?? null;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{route.title} — {cityMeta.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #F2EFEA;
        color: #2A2826;
        font-family: 'Manrope', sans-serif;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>
  <body>

    <!-- Header -->
    <header class="site-header">
      <a href={`/${cityMeta.slug}`} class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        Back to {cityMeta.name}
      </a>
      <span class="brand">loc_ Guide</span>
    </header>

    <!-- Content -->
    <main class="content">

      <!-- Itinerary header -->
      <div class="itinerary-header">
        <div>
          <span class="meta-label">Route</span>
          <h1 class="itinerary-title">{route.title}</h1>
          <p class="itinerary-desc">{route.description}</p>
        </div>
        <div class="itinerary-stats">
          <div class="stat-item">
            <span class="stat-label">Duration</span>
            <span class="stat-value">{route.duration}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Stops</span>
            <span class="stat-value">{String(route.steps.length).padStart(2, '0')} Places</span>
          </div>
          <div class="stat-item stat-last">
            <span class="stat-label">Vibe</span>
            <span class="stat-value">{route.vibe}</span>
          </div>
        </div>
      </div>

      <!-- Timeline -->
      <div class="timeline">
        {route.steps.map((step, i) => {
          const img = stepImage(step);
          return (
            <div class={`timeline-stop${i === route.steps.length - 1 ? ' last' : ''}`}>
              <!-- Col 1: stop number + time -->
              <div class="stop-left">
                <span class="stop-number">Stop / {String(i + 1).padStart(2, '0')}</span>
                <div class="stop-time">{step.time}</div>
              </div>

              <!-- Col 2: info -->
              <div class="stop-info">
                <div>
                  <h3 class="stop-title">{step.place_name}</h3>
                  <div class="stop-meta">
                    <span>{route.vibe}</span>
                    <span>{route.cost}</span>
                  </div>
                </div>
                <p class="stop-desc">{step.note}</p>
                {step.maps_url && (
                  <a href={step.maps_url} target="_blank" rel="noopener noreferrer" class="maps-link">
                    ↗ Open in Maps
                  </a>
                )}
              </div>

              <!-- Col 3: image -->
              <div class="stop-image">
                {img
                  ? <img src={img} alt={step.place_name} class="stop-img" />
                  : <div class="stop-img-placeholder" />
                }
              </div>
            </div>
          );
        })}
      </div>
    </main>

    <!-- End of Transmission -->
    <div class="eot-block">
      <span class="eot-text">End of Transmission.</span>
    </div>

  </body>
</html>

<style>
  :root {
    --accent: #C85A40;
    --serif: 'Instrument Serif', Georgia, serif;
  }
  /* Header */
  .site-header {
    width: 100%;
    padding: 2rem 4vw;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #D5D1CB;
  }
  .back-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #2A2826;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .back-link:hover { color: #C85A40; }
  .brand {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* Content */
  .content {
    padding: 5rem 4vw;
  }

  /* Itinerary header */
  .itinerary-header {
    margin-bottom: 5rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: end;
  }
  .meta-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #8A857D;
    display: block;
    margin-bottom: 1rem;
  }
  .itinerary-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .itinerary-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #8A857D;
    font-weight: 300;
    max-width: 50ch;
  }

  /* Stats */
  .itinerary-stats {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-left: 1px solid #D5D1CB;
    padding-left: 2rem;
  }
  .stat-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #D5D1CB;
    padding-bottom: 0.5rem;
  }
  .stat-last { border-bottom: none; padding-bottom: 0; }
  .stat-label { color: #8A857D; }
  .stat-value { color: #2A2826; font-weight: 500; }

  /* Timeline */
  .timeline {
    border-top: 1px solid #2A2826;
  }
  .timeline-stop {
    display: grid;
    grid-template-columns: 1fr 3fr 2fr;
    gap: 2rem;
    padding: 3rem 0;
    border-bottom: 1px solid #D5D1CB;
    align-items: start;
  }
  .timeline-stop.last {
    border-bottom: none;
  }

  /* Stop left */
  .stop-left { }
  .stop-number {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8A857D;
    margin-bottom: 0.5rem;
    display: block;
  }
  .stop-time {
    font-family: 'Instrument Serif', serif;
    font-size: 2.5rem;
    color: #C85A40;
    line-height: 1;
  }

  /* Stop info */
  .stop-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .stop-title {
    font-family: 'Instrument Serif', serif;
    font-size: 2rem;
    font-weight: 400;
    color: #2A2826;
    margin-bottom: 0.25rem;
  }
  .stop-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #8A857D;
  }
  .stop-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #2A2826;
    font-weight: 300;
  }
  .maps-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #C85A40;
    text-decoration: none;
    border: 1px solid #C85A40;
    padding: 5px 12px;
    border-radius: 2px;
    transition: background 0.15s;
    align-self: flex-start;
  }
  .maps-link:hover { background: #C85A40; color: #fff; }

  /* Stop image */
  .stop-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #D5D1CB;
  }
  .stop-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) contrast(1.1);
    display: block;
  }
  .stop-img-placeholder {
    width: 100%;
    height: 100%;
    background: #D5D1CB;
  }

  /* Footer */
  .eot-block {
    padding: 8rem 4vw; text-align: center;
    display: flex; align-items: center; justify-content: center;
    border-top: 1px solid var(--line);
  }
  .eot-text {
    font-family: var(--serif); font-size: 4rem; font-style: italic;
    color: var(--accent); opacity: 0.5; letter-spacing: -0.02em;
  }
  .site-footer {
    padding: 4rem 4vw;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #D3CABF;
    color: #4A453F;
  }
  .footer-copy {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .itinerary-header { grid-template-columns: 1fr; }
    .itinerary-stats { border-left: none; border-top: 1px solid #D5D1CB; padding-left: 0; padding-top: 1.5rem; }
    .timeline-stop { grid-template-columns: 1fr; gap: 1rem; }
    .stop-image { order: -1; }
    .stop-time { font-size: 2rem; }
  }
</style>
